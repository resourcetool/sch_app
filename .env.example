# ── EmailJS (Notifications) ───────────────────────────────────────
# Sign up at https://www.emailjs.com/ — free tier sends 200 emails/month.
# 1. Create a service (Gmail / Outlook / SMTP).
# 2. Create email templates with the variables listed below.
# 3. Paste the IDs below.
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Optional: separate EmailJS template for general super admin broadcasts
# If not set, falls back to VITE_EMAILJS_TEMPLATE_ID
VITE_EMAILJS_TEMPLATE_ID_GENERAL=template_general_xxxxxxx

# Optional: separate EmailJS template for trial expiry warnings sent to school admins
# Template variables: {{to_email}}, {{school_name}}, {{days_remaining}},
#   {{expiry_date}}, {{plan_name}}, {{upgrade_link}}, {{contact_phone}}, {{message}}
# If not set, falls back to VITE_EMAILJS_TEMPLATE_ID
VITE_EMAILJS_TEMPLATE_ID_EXPIRY=template_expiry_xxxxxxx

# ── EmailJS Template Variables Reference ─────────────────────────
# Access Request template (VITE_EMAILJS_TEMPLATE_ID):
#   {{to_email}}, {{school_name}}, {{admin_name}}, {{email}},
#   {{phone}}, {{school_type}}, {{region}}, {{plan}}, {{submitted_at}}
#
# Trial Expiry template (VITE_EMAILJS_TEMPLATE_ID_EXPIRY):
#   {{to_email}}, {{school_name}}, {{days_remaining}}, {{expiry_date}},
#   {{plan_name}}, {{upgrade_link}}, {{contact_phone}}, {{subject}}, {{message}}
