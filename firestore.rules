// firestore.rules
// FIXED: Removed if statements from withinDeadline function —
//        Firestore rules only allow ternary expressions, not if/else blocks

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ──────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuth() && (
        request.auth.token.superAdmin == true ||
        userDoc().role == 'superadmin'
      );
    }

    function isAdmin() {
      return isAuth() && userDoc().role == 'admin';
    }

    function isTeacher() {
      return isAuth() && userDoc().role == 'teacher';
    }

    function userSchoolId() {
      return isAuth() ? userDoc().schoolId : '';
    }

    function inSchool(schoolId) {
      return isAuth() && userDoc().schoolId == schoolId;
    }

    function isAdminOf(schoolId) {
      return isAdmin() && inSchool(schoolId);
    }

    function isTeacherOf(schoolId) {
      return isTeacher() && inSchool(schoolId);
    }

    function isMemberOf(schoolId) {
      return isAdminOf(schoolId) || isTeacherOf(schoolId);
    }

    // ── DEADLINE CHECK ────────────────────────────────────────────
    // Checks subject-specific window, falls back to class-wide window.
    // Returns true (open) when no window is configured.
    // Uses only boolean expressions — no if/else allowed in rules functions.

    function windowIsOpen(windowData) {
      return
        windowData.isLocked != true &&
        (
          !('openDate'  in windowData) ||
          windowData.openDate  == null ||
          request.time.toMillis() >= windowData.openDate
        ) &&
        (
          !('closeDate' in windowData) ||
          windowData.closeDate == null ||
          request.time.toMillis() <= windowData.closeDate
        );
    }

    function withinDeadline(schoolId, classId, academicYear, term, subjectId) {
      let subjectWindowId = schoolId + '_' + classId + '_' + academicYear + '_' + term + '_' + subjectId;
      let classWindowId   = schoolId + '_' + classId + '_' + academicYear + '_' + term + '_all';

      let hasSubjectWindow = exists(/databases/$(database)/documents/assessmentWindows/$(subjectWindowId));
      let hasClassWindow   = exists(/databases/$(database)/documents/assessmentWindows/$(classWindowId));

      // No window at all — entry is open
      // Subject window takes priority over class window
      return
        (!hasSubjectWindow && !hasClassWindow) ||
        (hasSubjectWindow &&
          windowIsOpen(
            get(/databases/$(database)/documents/assessmentWindows/$(subjectWindowId)).data
          )
        ) ||
        (!hasSubjectWindow && hasClassWindow &&
          windowIsOpen(
            get(/databases/$(database)/documents/assessmentWindows/$(classWindowId)).data
          )
        );
    }

    // ── SCHOOLS ──────────────────────────────────────────────────
    match /schools/{schoolId} {
      allow read:   if isSuperAdmin() || isMemberOf(schoolId);
      allow create: if isAuth();
      allow update: if isSuperAdmin() || isAdminOf(schoolId);
      allow delete: if false;
    }

    // ── USERS ────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth() && (
        uid() == userId ||
        isSuperAdmin() ||
        (isAdmin() && resource.data.schoolId == userSchoolId())
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        uid() == userId ||
        isSuperAdmin() ||
        isAdminOf(resource.data.schoolId)
      );
      allow delete: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
    }

    // ── STUDENTS ─────────────────────────────────────────────────
    match /students/{studentId} {
      allow read:   if isSuperAdmin() || isMemberOf(resource.data.schoolId);
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow delete: if false;
    }

    // ── ENROLLMENTS ───────────────────────────────────────────────
    match /enrollments/{enrollmentId} {
      allow read:   if isSuperAdmin() || isMemberOf(resource.data.schoolId);
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow delete: if false;
    }

    // ── TEACHERS ─────────────────────────────────────────────────
    match /teachers/{teacherId} {
      allow read:   if isSuperAdmin() || isMemberOf(resource.data.schoolId);
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow delete: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
    }

    // ── CLASSES ──────────────────────────────────────────────────
    match /classes/{classId} {
      allow read:   if isSuperAdmin() || isMemberOf(resource.data.schoolId);
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow delete: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
    }

    // ── SUBJECTS ─────────────────────────────────────────────────
    match /subjects/{subjectId} {
      allow read:   if isSuperAdmin() || isMemberOf(resource.data.schoolId);
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow delete: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
    }

    // ── SCORES ───────────────────────────────────────────────────
    match /scores/{scoreId} {
      allow read: if isSuperAdmin() || isMemberOf(resource.data.schoolId);

      allow create: if
        isSuperAdmin() ||
        isAdminOf(request.resource.data.schoolId) ||
        (
          isTeacherOf(request.resource.data.schoolId) &&
          request.resource.data.subjectId in userDoc().assignedSubjects &&
          request.resource.data.classId   in userDoc().assignedClasses  &&
          withinDeadline(
            request.resource.data.schoolId,
            request.resource.data.classId,
            request.resource.data.academicYear,
            request.resource.data.term,
            request.resource.data.subjectId
          )
        );

      allow update: if
        isSuperAdmin() ||
        isAdminOf(resource.data.schoolId) ||
        (
          isTeacherOf(resource.data.schoolId) &&
          resource.data.isFinalized  != true &&
          resource.data.isApproved   != true &&
          withinDeadline(
            resource.data.schoolId,
            resource.data.classId,
            resource.data.academicYear,
            resource.data.term,
            resource.data.subjectId
          )
        );

      allow delete: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
    }

    // ── RESULTS ──────────────────────────────────────────────────
    match /results/{resultId} {
      allow read:   if isSuperAdmin() || isMemberOf(resource.data.schoolId);
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if (isSuperAdmin() || isAdminOf(resource.data.schoolId))
                       && resource.data.isFinalized != true;
      allow delete: if false;
    }

    // ── PROMOTIONS ────────────────────────────────────────────────
    match /promotions/{promotionId} {
      allow read:   if isSuperAdmin() || isMemberOf(resource.data.schoolId);
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if false;
      allow delete: if false;
    }

    // ── ANALYTICS ────────────────────────────────────────────────
    match /analytics/{snapshotId} {
      allow read:   if isSuperAdmin() || isMemberOf(resource.data.schoolId);
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow delete: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
    }

    // ── ASSESSMENT WINDOWS ────────────────────────────────────────
    match /assessmentWindows/{windowId} {
      allow read:   if isSuperAdmin() || isMemberOf(resource.data.schoolId);
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow delete: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
    }

    // ── SCORE AUDIT LOG ───────────────────────────────────────────
    match /scoreAuditLog/{logId} {
      allow read:   if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if false;
      allow delete: if false;
    }

    // ── SUBSCRIPTIONS ─────────────────────────────────────────────
    match /subscriptions/{schoolId} {
      allow read:   if isSuperAdmin() || (isAuth() && userDoc().schoolId == schoolId);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if false;
    }

    // ── REGISTRATION CODES ────────────────────────────────────────
    match /registrationCodes/{codeId} {
      allow read:   if isAuth();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || isAuth();
      allow delete: if isSuperAdmin();
    }

    // ── ACCESS REQUESTS ───────────────────────────────────────────
    match /accessRequests/{requestId} {
      allow create: if true;
      allow read:   if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── BACKUPS ───────────────────────────────────────────────────
    match /backups/{backupId} {
      allow read:   if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if false;
      allow delete: if false;
    }

    // ── DEFAULT DENY ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
