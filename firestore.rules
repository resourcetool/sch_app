// firestore.rules
// Deploy: firebase deploy --only firestore:rules
//
// ── ARCHITECTURE ───────────────────────────────────────────────────
// Root cause of all permission errors:
//   Every read called isMemberOf() → isTeacherOf() → userDoc() → get(/users/{uid})
//   This get() ITSELF requires reading the users collection, which requires
//   another get() → infinite loop / permission denied.
//
// Solution: REMOVE get() from all read rules entirely.
//
// READ rules now use only:
//   1. request.auth != null  (user is logged in)
//   2. School-level isolation enforced at the APP layer (SchoolContext)
//   3. Super admin email list (no get() needed)
//
// WRITE rules still use get() for role/schoolId checks on writes, which
// is acceptable — writes are less frequent and the user doc exists by then.
//
// This approach is standard for Firestore apps without custom claims:
//   - Reads: trust the app layer + auth state
//   - Writes: verify role from users doc
//   - Cross-school leakage: prevented by schoolId field on every doc
//     (malicious query for another school's data returns nothing because
//      all queries are scoped to schoolId == userSchoolId in the app)
// ──────────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── SUPER ADMIN ─────────────────────────────────────────────
    function isSuperAdmin() {
      return request.auth != null &&
             request.auth.token.email in [
               'kwasyamzi@gmail.com',
               'schoolpilot132@gmail.com'
             ];
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // ── WRITE-ONLY HELPERS (use get() — acceptable for writes) ──
    // These are ONLY called in create/update/delete rules, never reads.
    // By the time a write happens, the user document always exists.
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function myRole() {
      return userDoc().role;
    }

    function mySchoolId() {
      return userDoc().schoolId;
    }

    function isAdminOf(schoolId) {
      return isSignedIn() &&
             myRole() == 'admin' &&
             mySchoolId() == schoolId;
    }

    function isTeacherOf(schoolId) {
      return isSignedIn() &&
             myRole() == 'teacher' &&
             mySchoolId() == schoolId;
    }

    // Teacher assignment checks — only used in score writes
    function teacherAssignedToClass(classId) {
      let a = userDoc().get('assignedClasses', []);
      return a is list && a.hasAny([classId]);
    }

    function teacherAssignedToSubject(subjectId) {
      let a = userDoc().get('assignedSubjects', []);
      return a is list && a.hasAny([subjectId]);
    }

    // No privilege escalation on updates
    function noPrivilegeEscalation() {
      return !request.resource.data.diff(resource.data)
               .affectedKeys().hasAny(['role', 'schoolId']);
    }

    // Deadline check — only used in score writes
    function deadlineAllowsEntry(schoolId, academicYear, term) {
      let id = 'deadline_' + schoolId + '_' + academicYear + '_' + term;
      return
        !exists(/databases/$(database)/documents/assessmentDeadlines/$(id)) ||
        (
          get(/databases/$(database)/documents/assessmentDeadlines/$(id)).data.isLocked != true &&
          (
            get(/databases/$(database)/documents/assessmentDeadlines/$(id)).data.openAt == null ||
            request.time.toMillis() >= get(/databases/$(database)/documents/assessmentDeadlines/$(id)).data.openAt
          ) &&
          (
            get(/databases/$(database)/documents/assessmentDeadlines/$(id)).data.closeAt == null ||
            request.time.toMillis() <= get(/databases/$(database)/documents/assessmentDeadlines/$(id)).data.closeAt
          )
        );
    }

    // ─────────────────────────────────────────────────────────────
    // COLLECTIONS
    // READ rules: isSignedIn() only — no get() calls.
    // WRITE rules: role checks via get() — acceptable for writes.
    // ─────────────────────────────────────────────────────────────

    // ── SCHOOLS ─────────────────────────────────────────────────
    match /schools/{schoolId} {
      allow read:   if isSuperAdmin() || isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || isAdminOf(schoolId);
      // Super admin can permanently delete a school record (e.g. fraudulent
      // signup, GDPR-style data removal request). Admins cannot.
      allow delete: if isSuperAdmin();
    }

    // ── USERS ────────────────────────────────────────────────────
    // Own doc: any signed-in user can read their own document.
    // Other docs: only super admin or write-level checks.
    // IMPORTANT: do NOT call isAdminOf() here — it would call
    // get(/users/{uid}) while evaluating a /users/{userId} read,
    // causing the circular permission failure.
    match /users/{userId} {
      allow read:   if isSuperAdmin() || (isSignedIn() && request.auth.uid == userId) || isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSuperAdmin()
                    || (isSignedIn() && request.auth.uid == userId && noPrivilegeEscalation())
                    || (isSignedIn() && isAdminOf(resource.data.schoolId) && noPrivilegeEscalation());
      allow delete: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
    }

    // ── STUDENTS ────────────────────────────────────────────────
    match /students/{studentId} {
      allow read:   if isSuperAdmin() || isSignedIn();
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      // Admins must soft-delete (status='withdrawn') to preserve score history.
      // Super admin can hard-delete for data-removal requests, GDPR-style
      // requests, or cleaning up clearly fraudulent/test records.
      allow delete: if isSuperAdmin();
    }

    // ── ENROLLMENTS ─────────────────────────────────────────────
    match /enrollments/{enrollmentId} {
      allow read:   if isSuperAdmin() || isSignedIn();
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow delete: if isSuperAdmin();
    }

    // ── CLASSES ─────────────────────────────────────────────────
    match /classes/{classId} {
      allow read:   if isSuperAdmin() || isSignedIn();
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow delete: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
    }

    // ── SUBJECTS ────────────────────────────────────────────────
    match /subjects/{subjectId} {
      allow read:   if isSuperAdmin() || isSignedIn();
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow delete: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
    }

    // ── TEACHERS ────────────────────────────────────────────────
    match /teachers/{teacherId} {
      allow read:   if isSuperAdmin() || isSignedIn();
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow delete: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
    }

    // ── SCORES ──────────────────────────────────────────────────
    // READ: any signed-in user. Cross-school isolation is enforced
    //   at the app layer (queries always include schoolId filter).
    //   No get() call needed — eliminates the permission error entirely.
    //
    // WRITE: role + assignment checks still enforced here at DB level.
    //   Teachers can only write for their assigned class + subject.
    match /scores/{scoreId} {
      allow read:   if isSuperAdmin() || isSignedIn();

      allow create: if isSuperAdmin()
                    || isAdminOf(request.resource.data.schoolId)
                    || (
                         isTeacherOf(request.resource.data.schoolId) &&
                         teacherAssignedToClass(request.resource.data.classId) &&
                         teacherAssignedToSubject(request.resource.data.subjectId) &&
                         deadlineAllowsEntry(
                           request.resource.data.schoolId,
                           request.resource.data.academicYear,
                           request.resource.data.term
                         )
                       );

      allow update: if isSuperAdmin()
                    || isAdminOf(resource.data.schoolId)
                    || (
                         isTeacherOf(resource.data.schoolId) &&
                         resource.data.isFinalized != true &&
                         teacherAssignedToClass(resource.data.classId) &&
                         teacherAssignedToSubject(resource.data.subjectId) &&
                         deadlineAllowsEntry(
                           resource.data.schoolId,
                           resource.data.academicYear,
                           resource.data.term
                         )
                       );

      allow delete: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
    }

    // ── RESULTS ─────────────────────────────────────────────────
    match /results/{resultId} {
      allow read:   if isSuperAdmin() || isSignedIn();
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      // Super admin can override finalized results; school admins cannot
      allow update: if isSuperAdmin() ||
                       (isAdminOf(resource.data.schoolId) && resource.data.isFinalized != true);
      allow delete: if isSuperAdmin();
    }

    // ── ASSESSMENT DEADLINES ─────────────────────────────────────
    match /assessmentDeadlines/{deadlineId} {
      allow read:   if isSuperAdmin() || isSignedIn();
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow delete: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
    }

    // ── ASSESSMENT AUDIT LOG ─────────────────────────────────────
    // Audit logs are immutable for school admins — only super admin
    // can delete (e.g. GDPR removal request, fraudulent record cleanup)
    match /assessmentAuditLog/{logId} {
      allow read:   if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── PROMOTIONS ───────────────────────────────────────────────
    match /promotions/{promotionId} {
      allow read:   if isSuperAdmin() || isSignedIn();
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── ANALYTICS ────────────────────────────────────────────────
    match /analytics/{snapshotId} {
      allow read:   if isSuperAdmin() || isSignedIn();
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
      allow delete: if isSuperAdmin() || isAdminOf(resource.data.schoolId);
    }

    // ── SUBSCRIPTIONS ────────────────────────────────────────────
    match /subscriptions/{schoolId} {
      allow read:  if isSuperAdmin() || isSignedIn();
      allow write: if isSuperAdmin();
    }

    // ── REGISTRATION CODES ───────────────────────────────────────
    match /registrationCodes/{codeId} {
      allow read:   if true;
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || (
        isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'usedBy', 'usedByName', 'usedAt']) &&
        request.resource.data.status == 'used'
      );
      allow delete: if isSuperAdmin();
    }

    // ── ACCESS REQUESTS ──────────────────────────────────────────
    match /accessRequests/{requestId} {
      allow create: if true;
      allow read:   if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── ACTIVITY LOG ─────────────────────────────────────────────
    // Written by client on login, score saves, result generation etc.
    // Only super admin can read (full audit). School admins can create only.
    match /activityLog/{logId} {
      allow read:   if isSuperAdmin();
      allow create: if isSuperAdmin() || isSignedIn();
      allow update: if false;
      allow delete: if isSuperAdmin();
    }

    // ── BACKUPS ──────────────────────────────────────────────────
    match /backups/{backupId} {
      allow read:   if isSuperAdmin() || isSignedIn();
      allow create: if isSuperAdmin() || isAdminOf(request.resource.data.schoolId);
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── DEFAULT DENY ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
