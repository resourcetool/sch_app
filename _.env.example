# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Firebase ─────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Super Admin Access ────────────────────────────────────────────
# Comma-separated list of super admin email addresses.
# All listed emails receive full super-admin access and email notifications.
VITE_SUPER_ADMIN_EMAILS=kwasyamzi@gmail.com,schoolpilot132@gmail.com

# ── EmailJS (Access Request Notifications) ────────────────────────
# Sign up at https://www.emailjs.com/ — free tier sends 200 emails/month.
# 1. Create a service (Gmail / Outlook / SMTP).
# 2. Create an email template with the variables listed in README.md.
# 3. Paste the IDs below.
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Optional: separate EmailJS template for general super admin broadcasts
# If not set, falls back to VITE_EMAILJS_TEMPLATE_ID
VITE_EMAILJS_TEMPLATE_ID_GENERAL=template_general_xxxxxxx
